DRIVER=~fastapi+~httpx+~websockets
# 让"注册""探索"等裸关键词指令(无 / 前缀)也能匹配;配合 to_me() 仍要求 @机器人
COMMAND_START=["", "/"]
# 沙箱阶段必须为 true,否则连的是正式环境、收不到沙箱里的消息
QQ_IS_SANDBOX=true
# 从 QQ 开放平台(q.qq.com)开发设置获取:复制本文件为 .env 再填入。密钥只放 .env,勿写进本模板。
# intent.c2c_group_at_messages=true 是接收「单聊/群」消息的开关,默认是关的,必须开!
QQ_BOTS='[{"id": "你的AppID", "token": "你的Token", "secret": "你的AppSecret", "intent": {"c2c_group_at_messages": true}}]'
