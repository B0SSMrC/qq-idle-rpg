# 普通 QQ 号 / OneBot v11 模式
# 使用方式:
#   1. 复制本文件为 .env
#   2. 启动 python -m bot.__main_onebot__
#   3. 在 NapCatQQ / Lagrange.OneBot 中配置反向 WebSocket 到:
#      ws://127.0.0.1:8080/onebot/v11/ws

DRIVER=~fastapi+~websockets
HOST=127.0.0.1
PORT=8080

# 允许「注册」「探索」等裸关键词，也允许「/探索」。
COMMAND_START=["", "/"]

# 群聊里建议 @机器人 后发指令；私聊可直接发指令。
# 如需在群里通过昵称触发，可把昵称加入这里，并确保协议端上报的消息内容包含昵称。
NICKNAME=["挂机RPG"]
