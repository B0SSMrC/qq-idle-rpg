# OneBot v11 mode.
# Copy this file to .env, then start:
#   python -m bot.__main_onebot__
#
# Configure NapCatQQ / Lagrange.OneBot reverse WebSocket to:
#   ws://127.0.0.1:8080/onebot/v11/ws

DRIVER=~fastapi+~websockets
HOST=127.0.0.1
PORT=8080

# Allow bare commands such as "注册" and slash commands such as "/探索".
COMMAND_START=["", "/"]

# In group chats, @ the bot or include this nickname.
NICKNAME=["挂机RPG"]
